<!DOCTYPE html>
<html class="h-full bg-slate-950">
  <head>
    <title><%= content_for(:title) || "Kamal Desk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-slate-100">
    <div class="min-h-full">
      <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
          <div>
            <%= link_to root_path, class: "text-lg font-semibold tracking-tight text-white" do %>
              Kamal Desk
            <% end %>
            <p class="text-sm text-slate-400">The missing web UI for Kamal deployments</p>
          </div>
        </div>
      </header>

      <% if flash[:notice].present? || flash[:alert].present? %>
        <div class="mx-auto max-w-7xl px-6 pt-4">
          <% if flash[:notice].present? %>
            <div class="rounded-lg border border-emerald-800 bg-emerald-950/50 px-4 py-3 text-emerald-200"><%= flash[:notice] %></div>
          <% end %>
          <% if flash[:alert].present? %>
            <div class="mt-2 rounded-lg border border-red-800 bg-red-950/50 px-4 py-3 text-red-200"><%= flash[:alert] %></div>
          <% end %>
        </div>
      <% end %>

      <main class="mx-auto max-w-7xl px-6 py-8">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
