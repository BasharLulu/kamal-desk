<% content_for :title, "Projects — Kamal Desk" %>

<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
  <section class="rounded-xl border border-slate-800 bg-slate-900 p-6">
    <h2 class="text-lg font-semibold text-white">Register project</h2>
    <p class="mt-2 text-sm text-slate-400">Point Kamal Desk at a folder containing <code class="text-slate-300">config/deploy.yml</code>.</p>

    <%= form_with model: @project, url: projects_path, class: "mt-4 space-y-4" do |form| %>
      <div>
        <%= form.label :root_path, "Project path", class: "mb-1 block text-sm text-slate-300" %>
        <%= form.text_field :root_path, placeholder: "/Users/you/Sites/my-app", class: "w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white" %>
      </div>
      <%= form.submit "Add project", class: "cursor-pointer rounded-lg bg-sky-600 px-4 py-2 font-medium text-white hover:bg-sky-500" %>
    <% end %>
  </section>

  <section>
    <h2 class="text-lg font-semibold text-white">Your Kamal projects</h2>
    <% if @projects.any? %>
      <div class="mt-4 grid gap-4">
        <% @projects.each do |project| %>
          <%= link_to project_path(project), class: "block rounded-xl border border-slate-800 bg-slate-900 p-5 transition hover:border-slate-600" do %>
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-medium text-white"><%= project.display_name %></h3>
                <p class="mt-1 text-sm text-slate-400"><%= project.root_path %></p>
              </div>
              <span class="rounded-full bg-slate-800 px-2 py-1 text-xs text-slate-300"><%= project.destinations.size %> destinations</span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 text-slate-400">No projects yet. Add a Kamal project path to get started.</p>
    <% end %>
  </section>
</div>
