<% content_for :title, "#{@project.display_name} — Kamal Desk" %>

<div class="mb-6 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-semibold text-white"><%= @project.display_name %></h1>
    <p class="mt-1 text-sm text-slate-400"><%= @project.root_path %></p>
  </div>
  <div class="flex gap-2">
    <%= button_to "Refresh", refresh_project_path(@project), method: :post, class: "rounded-lg border border-slate-700 px-3 py-2 text-sm text-slate-200 hover:bg-slate-800" %>
    <%= button_to "Remove", project_path(@project), method: :delete, form: { data: { turbo_confirm: "Remove this project from Kamal Desk?" } }, class: "rounded-lg border border-red-900 px-3 py-2 text-sm text-red-300 hover:bg-red-950" %>
  </div>
</div>

<%= render "shared/project_nav", project: @project, destination: @destination %>

<div class="grid gap-6 xl:grid-cols-[1fr_1.2fr]">
  <div class="space-y-6">
    <section class="rounded-xl border border-slate-800 bg-slate-900 p-6">
      <h2 class="text-lg font-semibold text-white">Configuration</h2>
      <% if @kamal_available %>
        <p class="mt-1 text-sm text-emerald-300">Kamal CLI is available for this project.</p>
      <% else %>
        <p class="mt-1 text-sm text-amber-300">Could not run kamal version in this project directory.</p>
      <% end %>

      <div class="mt-4 space-y-4">
        <% @config_summaries.each do |summary| %>
          <div class="rounded-lg border border-slate-800 bg-slate-950 p-4">
            <h3 class="font-medium text-white"><%= summary.destination %></h3>
            <% if summary.error %>
              <p class="mt-2 text-sm text-red-300"><%= summary.error %></p>
            <% else %>
              <dl class="mt-3 grid gap-2 text-sm text-slate-300">
                <div><dt class="text-slate-500">Service</dt><dd><%= summary.service %></dd></div>
                <div><dt class="text-slate-500">Image</dt><dd><%= summary.image %></dd></div>
                <div><dt class="text-slate-500">Proxy</dt><dd><%= summary.proxy_host.presence || "—" %> <%= summary.proxy_ssl ? "(TLS)" : "" %></dd></div>
                <div><dt class="text-slate-500">Hosts</dt><dd><%= summary.hosts.map { |h| "#{h[:role]}@#{h[:host]}" }.join(", ").presence || "—" %></dd></div>
                <div><dt class="text-slate-500">Accessories</dt><dd><%= summary.accessories.join(", ").presence || "—" %></dd></div>
                <div><dt class="text-slate-500">Aliases</dt><dd><%= summary.aliases.join(", ").presence || "—" %></dd></div>
              </dl>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-xl border border-slate-800 bg-slate-900 p-6">
      <h2 class="text-lg font-semibold text-white">Deploy history</h2>
      <% if @deployment_runs.any? %>
        <div class="mt-4 overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="text-slate-400">
              <tr>
                <th class="pb-2 pr-4">Command</th>
                <th class="pb-2 pr-4">Status</th>
                <th class="pb-2">Output</th>
              </tr>
            </thead>
            <tbody>
              <% @deployment_runs.each do |run| %>
                <tr class="border-t border-slate-800 text-slate-200">
                  <td class="py-3 pr-4"><code><%= run.command %></code></td>
                  <td class="py-3 pr-4"><span class="rounded-full px-2 py-1 text-xs <%= status_badge_class(run.status) %>"><%= run.status %></span></td>
                  <td class="py-3"><%= link_to "View", deployment_run_path(run), class: "text-sky-400 hover:text-sky-300" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="mt-4 text-slate-400">No deployments yet.</p>
      <% end %>
    </section>
  </div>

  <section class="rounded-xl border border-slate-800 bg-slate-900 p-6">
    <h2 class="text-lg font-semibold text-white">Operations</h2>
    <p class="mt-1 text-sm text-slate-400">Run Kamal commands with live output.</p>

    <div class="mt-3 rounded-lg border border-slate-800 bg-slate-950 p-3 text-xs text-slate-400">
      <strong class="text-slate-300">Lock:</strong>
      <pre class="mt-1 whitespace-pre-wrap text-slate-300"><%= @lock_status.presence || "Unknown" %></pre>
    </div>

    <%= form_with url: project_deployment_path(@project), scope: :deployment, class: "mt-4 space-y-4" do |form| %>
      <% if @project.destinations.any? %>
        <div>
          <%= form.label :destination, "Destination", class: "mb-1 block text-sm text-slate-300" %>
          <%= form.select :destination, options_for_select([["default", ""]] + @project.destinations.map { |d| [d, d] }, @destination), {}, class: "w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white" %>
        </div>
      <% end %>

      <div class="flex flex-wrap gap-2">
        <% %w[deploy redeploy setup].each do |command| %>
          <%= form.button command, name: "deployment[command]", value: command, class: "cursor-pointer rounded-lg bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-500" %>
        <% end %>
      </div>
    <% end %>

    <% if @active_run %>
      <div class="mt-6 border-t border-slate-800 pt-6">
        <div class="mb-3 flex items-center justify-between gap-3">
          <h3 class="text-sm font-medium text-white">Live: kamal <%= @active_run.command %></h3>
          <%= button_to "Cancel", cancel_deployment_run_path(@active_run), method: :post, class: "rounded-lg border border-amber-800 px-3 py-1 text-xs text-amber-200 hover:bg-amber-950" %>
        </div>
        <pre
          class="min-h-[320px] overflow-auto rounded-lg border border-slate-800 bg-black p-4 text-sm leading-6 text-emerald-300"
          data-controller="command-output"
          data-command-output-deployment-run-id-value="<%= @active_run.id %>"
        ><%= @active_run.output %></pre>
      </div>
    <% else %>
      <p class="mt-6 text-sm text-slate-500">Deploy output appears here while a command is running.</p>
    <% end %>
  </section>
</div>
