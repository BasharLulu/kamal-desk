<% content_for :title, "Proxy — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: params[:destination] %>

<%= render layout: "ui/card", locals: { title: "Proxy routes" } do %>
  <% if @routes.any? %>
    <%= render layout: "ui/table", locals: { headers: ["Service", "Host", "Target", "State", "TLS"] } do %>
      <% @routes.each do |route| %>
        <tr>
          <td><%= route.service %></td>
          <td><%= route.host %></td>
          <td><%= route.target %></td>
          <td><%= route.state %></td>
          <td><%= route.tls %></td>
        </tr>
      <% end %>
    <% end %>
  <% else %>
    <%= render "ui/empty_state", message: "No routes parsed from kamal-proxy list.", icon: "globe" %>
  <% end %>
<% end %>

<%= render layout: "ui/card", locals: { title: "Proxy details", extra_class: "mt-6" } do %>
  <%= render "ui/terminal", content: @details %>
<% end %>
