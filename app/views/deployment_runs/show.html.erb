<% content_for :title, "Deployment — Kamal Desk" %>

<div class="mb-4 flex items-center justify-between gap-4">
  <%= link_to "← Back to #{@project.display_name}", project_path(@project), class: "ui-link" %>
  <% if @deployment_run.running? %>
    <%= button_to "Cancel", cancel_deployment_run_path(@deployment_run), method: :post, class: ui_btn_class(:warning) %>
  <% end %>
</div>

<h1 class="ui-page-title">kamal <%= @deployment_run.command %></h1>
<p class="ui-muted mt-1">
  <%= @project.display_name %> · <%= @deployment_run.destination.presence || "default" %>
  · <%= status_badge(@deployment_run.status) %>
</p>

<%= render "ui/terminal",
  content: @deployment_run.output,
  variant: :live,
  min_height: "mt-6 min-h-[480px]",
  data: {
    controller: "command-output",
    command_output_deployment_run_id_value: @deployment_run.id
  } %>
