<% content_for :title, "Accessories — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: @destination %>

<% summaries = Kamal::ConfigLoader.new(project: @project).summaries %>
<% summary = summaries.find { |s| s.destination == (@destination.presence || "default") } || summaries.first %>
<% accessories = summary&.accessories || [] %>

<section class="rounded-xl border border-slate-800 bg-slate-900 p-6">
  <h2 class="text-lg font-semibold text-white">Accessories</h2>
  <% if accessories.any? %>
    <div class="mt-4 space-y-3">
      <% accessories.each do |accessory| %>
        <div class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-slate-800 bg-slate-950 px-4 py-3">
          <span class="font-medium text-white"><%= accessory %></span>
          <div class="flex gap-2">
            <%= button_to "Boot", project_accessories_path(@project, destination: @destination), method: :post, params: { accessory: accessory, accessory_action: "boot" }, class: "rounded-lg bg-sky-600 px-3 py-1 text-xs text-white hover:bg-sky-500" %>
            <%= button_to "Logs", project_accessories_path(@project, destination: @destination), method: :post, params: { accessory: accessory, accessory_action: "logs" }, class: "rounded-lg border border-slate-700 px-3 py-1 text-xs text-slate-200 hover:bg-slate-800" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-4 text-slate-400">No accessories configured for this destination.</p>
  <% end %>

  <% latest = @project.command_runs.order(created_at: :desc).first %>
  <% if latest&.output.present? %>
    <h3 class="mt-8 text-sm font-medium text-slate-300">Latest command output</h3>
    <pre class="mt-2 overflow-auto rounded-lg bg-black p-4 text-xs text-slate-300"><%= Kamal::SecretFilter.redact(latest.output) %></pre>
  <% end %>
</section>
