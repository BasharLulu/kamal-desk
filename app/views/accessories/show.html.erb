<% content_for :title, "Accessories — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: @destination %>

<% summaries = Kamal::ConfigLoader.new(project: @project).summaries %>
<% summary = summaries.find { |s| s.destination == (@destination.presence || "default") } || summaries.first %>
<% accessories = summary&.accessories || [] %>

<%= render layout: "ui/card", locals: { title: "Accessories" } do %>
  <% if accessories.any? %>
    <div class="space-y-3">
      <% accessories.each do |accessory| %>
        <div class="flex flex-wrap items-center justify-between gap-3 ui-card-inner">
          <span class="flex items-center gap-2 font-medium text-slate-900 dark:text-white">
            <%= icon("puzzle", css_class: "h-4 w-4 text-slate-400") %>
            <%= accessory %>
          </span>
          <div class="flex gap-2">
            <%= button_to "Boot", project_accessories_path(@project, destination: @destination), method: :post, params: { accessory: accessory, accessory_action: "boot" }, class: ui_btn_class(:primary, size: :xs) %>
            <%= button_to "Logs", project_accessories_path(@project, destination: @destination), method: :post, params: { accessory: accessory, accessory_action: "logs" }, class: ui_btn_class(:secondary, size: :xs) %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "ui/empty_state", message: "No accessories configured for this destination.", icon: "puzzle" %>
  <% end %>

  <% latest = @project.command_runs.order(created_at: :desc).first %>
  <% if latest&.output.present? %>
    <h3 class="mt-8 text-sm font-medium text-slate-700 dark:text-slate-300">Latest command output</h3>
    <%= render "ui/terminal", content: Kamal::SecretFilter.redact(latest.output), variant: :compact, class: "mt-2" %>
  <% end %>
<% end %>
