<% content_for :title, "Containers — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: params[:destination] %>

<div class="grid gap-6 lg:grid-cols-2">
  <%= render layout: "ui/card", locals: { title: "Containers" } do %>
    <%= render "ui/terminal", content: @containers %>
  <% end %>
  <%= render layout: "ui/card", locals: { title: "App details" } do %>
    <%= render "ui/terminal", content: @details %>
  <% end %>
</div>

<%= render layout: "ui/card", locals: { title: "kamal details", extra_class: "mt-6" } do %>
  <%= render "ui/terminal", content: @all_details %>
<% end %>

<%= render layout: "ui/card", locals: { title: "Rollback versions", extra_class: "mt-6" } do %>
  <% if @versions.any? %>
    <div class="flex flex-wrap gap-2">
      <% @versions.each do |version| %>
        <%= button_to version[0, 12], project_deployment_path(@project), method: :post, params: { deployment: { command: "rollback", version: version, destination: params[:destination] } }, class: ui_btn_class(:secondary) %>
      <% end %>
    </div>
  <% else %>
    <%= render "ui/empty_state", message: "No rollback versions detected.", icon: "cube" %>
  <% end %>
<% end %>
