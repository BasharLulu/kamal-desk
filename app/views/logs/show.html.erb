<% content_for :title, "Logs — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: @destination %>

<%= render layout: "ui/card", locals: {
  title: "kamal app logs -f",
  actions: capture do
    if @active_run&.running?
      button_to("Stop", project_logs_path(@project, destination: @destination), method: :delete, class: ui_btn_class(:warning))
    else
      button_to("Start streaming", project_logs_path(@project, destination: @destination), method: :post, class: ui_btn_class(:primary))
    end
  end
} do %>
  <div data-controller="log-stream" data-log-stream-command-run-id-value="<%= @active_run&.id %>">
    <button
      type="button"
      data-action="log-stream#togglePause"
      data-log-stream-target="pauseButton"
      class="<%= ui_btn_class(:secondary, size: :xs) %> mb-3"
    >Pause auto-scroll</button>
    <%= render "ui/terminal",
      content: @active_run&.output,
      variant: :live,
      min_height: "min-h-[480px]",
      data: { log_stream_target: "output" } %>
  </div>
<% end %>
