<% destination = local_assigns[:destination] %>
<nav class="mb-8 flex flex-wrap gap-2 border-b border-slate-800 pb-4 text-sm">
  <%= link_to "Overview", project_path(project, destination: destination), class: nav_link_class(request.path, project_path(project)) %>
  <%= link_to "Containers", project_containers_path(project, destination: destination), class: nav_link_class(request.path, project_containers_path(project)) %>
  <%= link_to "Proxy", project_proxy_path(project, destination: destination), class: nav_link_class(request.path, project_proxy_path(project)) %>
  <%= link_to "Audit", project_audit_path(project, destination: destination), class: nav_link_class(request.path, project_audit_path(project)) %>
  <%= link_to "Server load", project_server_metrics_path(project, destination: destination), class: nav_link_class(request.path, project_server_metrics_path(project)) %>
</nav>

<% if project.destinations.any? %>
  <div class="mb-6 flex flex-wrap items-center gap-2 text-sm">
    <span class="text-slate-400">Destination:</span>
    <%= link_to "default", url_for(destination: nil), class: destination_chip_class(destination.blank?) %>
    <% project.destinations.each do |dest| %>
      <%= link_to dest, url_for(destination: dest), class: destination_chip_class(destination == dest) %>
    <% end %>
  </div>
<% end %>
