<% destination = local_assigns[:destination] %>
<% project = local_assigns[:project] %>

<%= render "shared/destination_selector", project: project, destination: destination %>

<nav class="mb-6 overflow-x-auto" aria-label="Project sections">
  <div class="flex min-w-max gap-1 border-b border-slate-200 pb-3 dark:border-slate-800">
    <% nav_links = [
      [ "Overview", :project_path ],
      [ "Containers", :project_containers_path ],
      [ "Proxy", :project_proxy_path ],
      [ "Accessories", :project_accessories_path ],
      [ "Server load", :project_server_metrics_path ],
      [ "Logs", :project_logs_path ],
      [ "Console", :project_console_path ],
      [ "Audit", :project_audit_path ]
    ] %>

    <% nav_links.each do |label, path_helper| %>
      <% target_path = send(path_helper, project, destination: destination) %>
      <%= link_to label, target_path, class: nav_link_class(request.path, target_path) %>
    <% end %>
  </div>
</nav>
