<% actions = local_assigns[:actions] %>

<div class="mb-6 flex items-start justify-between gap-4">
  <div>
    <h1 class="ui-page-title"><%= @project.display_name %></h1>
    <p class="ui-muted mt-1"><%= @project.root_path %></p>
  </div>
  <% if actions.present? %>
    <div class="flex shrink-0 flex-wrap gap-2"><%= actions %></div>
  <% end %>
</div>
