<% content_for :title, "Server load — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: params[:destination] %>

<%= render layout: "ui/card", locals: {
  title: "docker stats",
  actions: content_tag(:span, "Auto-refreshes every 15s", class: "ui-muted text-xs")
} do %>
  <div
    data-controller="poll-refresh"
    data-poll-refresh-url-value="<%= refresh_project_server_metrics_path(@project, destination: params[:destination]) %>"
    data-poll-refresh-interval-value="15000"
  >
    <div data-poll-refresh-target="output">
      <%= render "server_metrics/metrics", metrics: @metrics %>
    </div>
  </div>
<% end %>
