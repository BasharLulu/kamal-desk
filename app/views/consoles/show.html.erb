<% content_for :head do %>
  <%= stylesheet_link_tag "xterm", "data-turbo-track": "reload" %>
<% end %>

<% content_for :title, "Console — #{@project.display_name}" %>
<%= render "shared/project_header" %>
<%= render "shared/project_nav", project: @project, destination: @destination %>

<div class="ui-alert-warning mb-4">
  You are executing code on a remote server. Proceed with caution.
</div>

<%= render layout: "ui/card", locals: {
  title: "Remote Rails console",
  actions: capture do
    if @active_run&.running?
      button_to("Close console", project_console_path(@project, destination: @destination), method: :delete, class: ui_btn_class(:warning))
    else
      button_to("Open console", project_console_path(@project, destination: @destination), method: :post, class: ui_btn_class(:primary))
    end
  end
} do %>
  <% if @active_run&.running? %>
    <div
      class="mt-4 h-[480px] overflow-hidden rounded-lg border border-slate-200 bg-slate-900 p-2 dark:border-slate-800 dark:bg-black"
      data-controller="terminal"
      data-terminal-command-run-id-value="<%= @active_run.id %>"
    ></div>
  <% else %>
    <p class="ui-muted">Open a console session to run Ruby on the remote app container.</p>
  <% end %>
<% end %>
